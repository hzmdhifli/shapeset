		<string>This app requires access to the photo library to upload your progress pictures and profile photo.</string>
		<key>NSCameraUsageDescription</key>
		<string>This app requires access to the camera to take your progress pictures and profile photo.</string>
		<key>NSMicrophoneUsageDescription</key>
		<string>This app requires access to the microphone for recording video check-ins.</string>
