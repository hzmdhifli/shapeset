		<array>
			<dict>
				<key>CFBundleTypeRole</key>
				<string>Editor</string>
				<key>CFBundleURLSchemes</key>
				<array>
					<string>com.googleusercontent.apps.377637374809-gqfdg7dieumscc535r4618u55ahqqh4j</string>
				</array>
			</dict>
		</array>
